<view
  class="flex flex-col w-full relative"
  style="height:100vh; overflow:hidden; background:#F2EDE7;"
>

  <view
    class="flex items-center"
    style="padding:56px 24px 0; justify-content:space-between; position:relative; z-index:50;"
  >
    <view
      wx:if="{{hasHistory}}"
      style="width:40px; height:40px; border-radius:50%; background:#1A1A1A; display:flex; align-items:center; justify-content:center;"
      catchtap="onGoBack"
    >
      <text style="font-size:18px; color:#F2EDE7; font-weight:300;">‹</text>
    </view>
    <view wx:else style="width:40px; height:40px;"></view>

    <view style="display:flex; align-items:center; gap:12px;">
      <view
        wx:if="{{currentSentence}}"
        class="bookmark-btn"
        style="width:40px; height:40px; border-radius:50%; background:rgba(26,26,26,0.06); display:flex; align-items:center; justify-content:center;"
        catchtap="onTapBookmark"
        data-sentence-id="{{currentSentence.id}}"
        data-book-idx="{{bookIndex}}"
        data-sentence-idx="{{sentenceIndex}}"
      >
        <text style="font-size:16px;">{{currentSentence.is_bookmarked ? '♥' : '♡'}}</text>
      </view>
    </view>
  </view>

  <view style="padding:12px 28px 0; position:relative; z-index:20;">
    <view style="font-size:13px; color:rgba(26,26,26,0.4); font-weight:500; letter-spacing:0.03em;">{{currentBookTitle}}</view>
  </view>

  <view
    wx:if="{{showSprout}}"
    style="padding:8px 28px 4px; position:relative; z-index:25;"
    bindtap="onTapSprout"
  >
    <view style="font-size:13px; color:rgba(26,26,26,0.35); font-weight:400; line-height:1.6; letter-spacing:0.02em;">
      {{sproutText}}<text wx:if="{{sproutTargetId}}" style="color:rgba(26,26,26,0.5); margin-left:4px;">›</text>
    </view>
  </view>

  <view
    wx:if="{{showWelcome && !showSprout}}"
    style="padding:4px 28px; position:relative; z-index:25;"
  >
    <view style="display:inline-block; padding:5px 14px; border-radius:12px; background:rgba(140,200,100,0.15); font-size:13px; color:rgba(80,120,50,0.7); font-weight:500; line-height:1.6; letter-spacing:0.02em;">
      {{welcomeText}}
    </view>
  </view>

  <view style="flex:1; position:relative; z-index:10; overflow:hidden;">
    <view wx:if="{{hintVertical}}" class="pointer-events-none" style="position:absolute; left:0; right:0; top:0; bottom:0; z-index:30;">
      <view id="hint-down" style="position:absolute; bottom:8px; left:50%; transform:translateX(-50%); width:44px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:14px; background:rgba(26,26,26,0.06);">
        <text style="color:rgba(26,26,26,0.3); font-size:20px; font-weight:300; transform:rotate(90deg);">›</text>
      </view>
    </view>
    <view wx:if="{{hintHorizontal}}" class="pointer-events-none" style="position:absolute; left:0; right:0; top:0; bottom:0; z-index:30;">
      <view id="hint-left" style="position:absolute; left:4px; top:50%; transform:translateY(-50%); width:28px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:14px; background:rgba(26,26,26,0.06);">
        <text style="color:rgba(26,26,26,0.3); font-size:20px; font-weight:300;">‹</text>
      </view>
      <view id="hint-right" style="position:absolute; right:4px; top:50%; transform:translateY(-50%); width:28px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:14px; background:rgba(26,26,26,0.06);">
        <text style="color:rgba(26,26,26,0.3); font-size:20px; font-weight:300;">›</text>
      </view>
    </view>

    <swiper
      style="width:100%; height:100%;"
      current="{{bookIndex}}"
      previous-margin="28px"
      next-margin="28px"
      bindchange="onBookChange"
      easing-function="easeInOutCubic"
      duration="{{350}}"
    >
      <block wx:for="{{books}}" wx:for-index="bIdx" wx:key="bIdx">
        <swiper-item>
          <view style="width:100%; height:100%; padding:0 8px;">
          <swiper
            vertical
            style="width:100%; height:100%;"
            current="{{bIdx === bookIndex ? sentenceIndex : 0}}"
            previous-margin="20px"
            next-margin="20px"
            bindchange="onSentenceChange"
            data-book-index="{{bIdx}}"
            easing-function="easeInOutCubic"
            duration="{{300}}"
          >
            <block wx:for="{{item.sentences}}" wx:for-item="sentence" wx:for-index="sIdx" wx:key="sIdx">
              <swiper-item>
                <view style="height:100%; padding:6px 0; position:relative;">

                  <view
                    id="{{bIdx === bookIndex && sIdx === sentenceIndex ? 'card-front' : ''}}"
                    style="position:absolute; left:0; right:0; top:6px; bottom:6px; border-radius:24px; background:#FAF7F2; box-shadow:0 1px 4px rgba(26,26,26,0.04),0 6px 24px rgba(26,26,26,0.03); display:flex; flex-direction:column; overflow:hidden; opacity:{{bIdx === bookIndex ? 1 : 0.6}}; z-index:2;"
                  >
                    <image wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex}}" src="{{cardIllustration}}" style="position:absolute; right:-10px; top:-5px; width:120px; height:120px; opacity:0.12;" mode="aspectFit" />
                    <view style="flex:1; display:flex; flex-direction:column; justify-content:center; padding:0 24px; overflow:hidden;" catchtap="onTapSentence">

                      <view
                        wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex && sentence.context_before}}"
                        style="position:relative; overflow:hidden; display:flex; flex-direction:column; justify-content:flex-end; max-height:{{contextOpen ? 300 : 27}}px;"
                      >
                        <text style="font-size:14px; line-height:1.9; font-weight:400; color:rgba(26,26,26,{{contextOpen ? 0.35 : 0.15}});">{{sentence.context_before}}</text>
                        <view
                          wx:if="{{!contextOpen}}"
                          style="position:absolute; left:0; right:0; top:0; bottom:0; background:linear-gradient(to bottom, #FAF7F2, transparent); pointer-events:none;"
                        ></view>
                      </view>

                      <view style="font-size:{{bIdx === bookIndex && sIdx === sentenceIndex ? currentFontSize : 17}}px; font-weight:900; color:#1A1A1A; line-height:1.7; letter-spacing:-0.01em; padding:8px 0;">
                        {{sentence.text}}
                      </view>

                      <view
                        wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex && sentence.context_after}}"
                        style="position:relative; overflow:hidden; max-height:{{contextOpen ? 300 : 27}}px;"
                      >
                        <text style="font-size:14px; line-height:1.9; font-weight:400; color:rgba(26,26,26,{{contextOpen ? 0.35 : 0.15}});">{{sentence.context_after}}</text>
                        <view
                          wx:if="{{!contextOpen}}"
                          style="position:absolute; left:0; right:0; top:0; bottom:0; background:linear-gradient(to top, #FAF7F2, transparent); pointer-events:none;"
                        ></view>
                      </view>

                    </view>

                    <view wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex}}" style="padding:0 24px 16px;">
                      <view style="font-size:13px; color:rgba(26,26,26,0.4); font-weight:500; letter-spacing:0.03em;">
                        <text wx:if="{{currentAuthorMultiBook}}" catchtap="onTapAuthorName" data-author="{{item.book.author}}" style="border-bottom:1px dashed rgba(26,26,26,0.2);">{{item.book.author}}</text>
                        <text wx:else>{{item.book.author}}</text>
                      </view>
                      <view wx:if="{{!contextOpen && sentence.chapter}}" style="font-size:11px; color:rgba(26,26,26,0.2); margin-top:4px;">
                        {{sentence.chapter}}
                      </view>
                      <view
                        wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex && seedEchoVisible}}"
                        id="seed-echo"
                        style="font-size:12px; color:rgba(26,26,26,0.3); font-weight:400; margin-top:10px;"
                      >
                        {{seedEchoText}}
                      </view>
                    </view>
                    <view
                      wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex && !isFlipped}}"
                      style="display:flex; align-items:flex-end; justify-content:flex-end; padding:0 20px 20px;"
                    >
                      <view
                        id="flip-vortex"
                        style="width:68px; height:68px; border-radius:50%; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; box-shadow:0 4px 20px rgba(107,196,31,0.35);"
                        catchtap="onTapFlip"
                      >
                        <view id="flip-vortex-bg" style="position:absolute; left:0; right:0; top:0; bottom:0; border-radius:50%; background:conic-gradient(from 0deg, #6BC41F, #A8E063, #4ADE80, #22C55E, #6BC41F);"></view>
                        <text style="position:relative; z-index:2; font-size:20px; font-weight:900; color:#fff;">翻</text>
                      </view>
                    </view>
                  </view>

                  <view
                    wx:if="{{bIdx === bookIndex && sIdx === sentenceIndex}}"
                    id="card-back"
                    style="position:absolute; left:0; right:0; top:6px; bottom:6px; border-radius:24px; background:#FAF7F2; box-shadow:0 1px 4px rgba(26,26,26,0.04),0 6px 24px rgba(26,26,26,0.03); display:flex; flex-direction:column; overflow:hidden; z-index:1;"
                  >
                    <image src="{{flipIllustration}}" style="position:absolute; left:-15px; bottom:-10px; width:100px; height:100px; opacity:0.08;" mode="aspectFit" />
                    <view style="flex:1; display:flex; flex-direction:column; justify-content:center; padding:0 24px;">
                      <view style="display:inline-block; padding:7px 20px; border-radius:50px; background:rgba(180,100,50,0.08); font-size:13px; font-weight:700; letter-spacing:0.1em; color:rgba(160,90,40,0.8); margin-bottom:18px;">反面</view>
                      <view style="font-size:20px; font-weight:700; line-height:1.85; color:#1A1A1A;" catchtap="onTapRelatedQuote" data-sentence-id="{{flipOq.sentence_id}}">
                        {{flipOq.text}}
                        <text wx:if="{{flipOq.sentence_id}}" style="color:rgba(26,26,26,0.2); font-weight:400;"> ›</text>
                      </view>
                      <view style="font-size:12px; color:rgba(26,26,26,0.3); margin-top:12px; font-weight:500;">
                        <text wx:if="{{flipOq.book_found}}" catchtap="onTapRelatedBookTitle" data-book-title="{{flipOq.book_title}}" style="border-bottom:1px dashed rgba(26,26,26,0.15);">《{{flipOq.book_title}}》</text>
                        <text wx:else>《{{flipOq.book_title}}》</text>
                        <text>  </text>
                        <text wx:if="{{flipOq.author_multi_book}}" catchtap="onTapRelatedAuthor" data-author="{{flipOq.book_author}}" style="border-bottom:1px dashed rgba(26,26,26,0.15);">{{flipOq.book_author}}</text>
                        <text wx:else>{{flipOq.book_author}}</text>
                      </view>
                    </view>
                    <view style="display:flex; align-items:flex-end; justify-content:flex-end; padding:0 20px 20px; gap:12px;">
                      <view
                        style="padding:12px 20px; border-radius:50px; background:rgba(26,26,26,0.06); font-size:13px; font-weight:600; color:rgba(26,26,26,0.35);"
                        catchtap="onTapBack"
                      >
                        <text>← 回</text>
                      </view>
                    </view>
                  </view>

                </view>
              </swiper-item>
            </block>
          </swiper>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view style="padding:4px 28px 0; position:relative; z-index:20;">
    <view style="height:3px; background:rgba(26,26,26,0.06); border-radius:2px; overflow:hidden;">
      <view style="height:100%; width:{{(sentenceIndex + 1) / totalSentences * 100}}%; background:#1A1A1A; border-radius:2px;"></view>
    </view>
    <view style="display:flex; justify-content:flex-end; margin-top:6px;">
      <text style="font-size:10px; color:rgba(26,26,26,0.25); font-weight:500;">{{sentenceIndex + 1}} / {{totalSentences}}</text>
    </view>
  </view>

  <view
    wx:if="{{toastVisible}}"
    style="position:absolute; left:20px; right:20px; top:100px; z-index:60; padding:12px 16px; border-radius:16px; background:rgba(242,237,231,0.95); border:1px solid rgba(26,26,26,0.06); box-shadow:0 2px 12px rgba(26,26,26,0.06);"
    bindtap="onTapToast"
  >
    <view style="display:flex; align-items:center; gap:8px;">
      <text style="font-size:14px;">🌱</text>
      <text style="font-size:13px; font-weight:500; color:rgba(26,26,26,0.5); flex:1;">{{toastHook}}</text>
      <text style="font-size:14px; color:rgba(26,26,26,0.2); font-weight:300;">›</text>
    </view>
  </view>

  <view style="display:flex; align-items:center; justify-content:center; gap:32px; padding:10px 0 28px; position:relative; z-index:20;">
    <view class="flex flex-col items-center" style="gap:2px;">
      <text style="font-size:18px;">📖</text>
      <text style="font-size:10px; font-weight:600; color:#1A1A1A;">翻翻</text>
    </view>
    <view id="tab-garden" class="flex flex-col items-center" style="gap:2px;" bindtap="goToMine">
      <text style="font-size:18px;">🌱</text>
      <text style="font-size:10px; font-weight:600; color:rgba(26,26,26,0.25);">花园</text>
    </view>
    <view class="flex flex-col items-center" style="gap:2px;" bindtap="goToProfile">
      <text style="font-size:18px;">👤</text>
      <text style="font-size:10px; font-weight:600; color:rgba(26,26,26,0.25);">我的</text>
    </view>
  </view>

  <view
    id="seed-dot"
    style="width:6px; height:6px; border-radius:50%; background:rgba(76,140,100,0.6); position:absolute; z-index:99; opacity:0;"
  ></view>

  <view
    wx:if="{{showBookOverlay}}"
    class="absolute inset-0 flex flex-col items-center justify-center"
    style="z-index:70; background:rgba(242,237,231,0.94);"
  >
    <image src="{{overlayIllustration}}" style="width:160px; height:160px; margin-bottom:20px; opacity:0.7;" mode="aspectFit" />
    <view style="font-size:28px; font-weight:900; color:#1A1A1A; letter-spacing:-0.01em;">{{overlayBookTitle}}</view>
    <view style="font-size:14px; color:rgba(26,26,26,0.4); margin-top:10px; font-weight:500;">{{overlayBookAuthor}}</view>
    <view style="font-size:11px; color:rgba(26,26,26,0.2); margin-top:16px;">{{overlayBookCount}} 句</view>
  </view>

  <view
    wx:if="{{showSheet}}"
    class="absolute inset-0"
    style="z-index:80; background:rgba(0,0,0,0.3);"
    catchtap="onCloseSheet"
  ></view>
  <view
    wx:if="{{showSheet}}"
    style="position:absolute; bottom:0; left:0; right:0; z-index:90; background:#F2EDE7; border-top:1px solid rgba(26,26,26,0.06); border-radius:24px 24px 0 0; padding:20px 24px 40px;"
  >
    <view style="width:36px; height:4px; border-radius:2px; background:rgba(26,26,26,0.1); margin:0 auto 16px;"></view>
    <view style="font-size:16px; font-weight:900; color:#1A1A1A; text-align:center; margin-bottom:16px;">{{sheetAuthor}}</view>
    <view style="display:flex; flex-direction:column; gap:8px;">
      <block wx:for="{{sheetBooks}}" wx:key="bookIndex">
        <view
          style="display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-radius:16px; background:rgba(26,26,26,0.03);"
          catchtap="onSheetBookTap"
          data-book-index="{{item.bookIndex}}"
        >
          <view>
            <view style="font-size:14px; font-weight:700; color:#1A1A1A;">《{{item.title}}》</view>
            <view style="font-size:11px; color:rgba(26,26,26,0.3); margin-top:2px;">{{item.sentenceCount}} 句</view>
          </view>
          <text style="font-size:16px; color:rgba(26,26,26,0.2); font-weight:300;">›</text>
        </view>
      </block>
    </view>
  </view>

</view>
