<view class="flex flex-col w-full bg-bg relative" style="height:100vh; overflow:hidden;">
  <view class="absolute inset-0 pointer-events-none overflow-hidden">
    <view class="absolute rounded-full" style="width:320px; height:320px; background:rgba(52,211,153,0.055); top:-80px; left:-50px;"></view>
    <view class="absolute rounded-full" style="width:280px; height:280px; background:rgba(240,160,80,0.04); bottom:20%; right:-70px;"></view>
  </view>

  <view style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:0 40px; position:relative; z-index:10;">
    <view style="margin-bottom:40px; text-align:center;">
      <text style="font-size:28px; font-weight:600; color:#E8F0EC; letter-spacing:0.05em;">OneLiner</text>
      <view class="text-sm text-text-dim" style="margin-top:8px;">登录后即可收藏喜欢的句子</view>
    </view>

    <button
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
      style="width:80px; height:80px; border-radius:50%; padding:0; margin:0; overflow:hidden; background:rgba(255,255,255,0.06); border:1px solid rgba(52,211,153,0.15); display:flex; align-items:center; justify-content:center;"
    >
      <image
        wx:if="{{avatarUrl}}"
        src="{{avatarUrl}}"
        style="width:80px; height:80px; border-radius:50%;"
      />
      <view wx:else style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:80px; height:80px;">
        <text style="font-size:28px;">📷</text>
        <text class="text-xs text-text-dim" style="margin-top:4px;">选头像</text>
      </view>
    </button>

    <view style="width:100%; margin-top:24px;">
      <input
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
        style="width:100%; height:44px; border-radius:22px; padding:0 20px; font-size:15px; color:#E8F0EC; background:rgba(255,255,255,0.05); border:1px solid rgba(52,211,153,0.12); text-align:center;"
        placeholder-style="color:#546E64;"
      />
    </view>

    <view
      style="width:100%; margin-top:32px; padding:14px 0; border-radius:22px; text-align:center; background:linear-gradient(135deg,#34D399,#F0A050); opacity:{{canSubmit ? 1 : 0.4}};"
      bindtap="onTapConfirm"
    >
      <text class="text-white text-sm font-semibold tracking-wider">确认登录</text>
    </view>

    <view style="margin-top:16px;" bindtap="onTapSkip">
      <text class="text-xs text-text-faint">跳过，稍后再说</text>
    </view>
  </view>
</view>
