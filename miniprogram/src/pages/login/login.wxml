<view class="flex flex-col w-full relative" style="height:100vh; overflow:hidden; background:#F2EDE7;">

  <view style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:0 36px; position:relative; z-index:10;">

    <image src="/assets/illustrations/mascot.png" style="width:140px; height:140px; margin-bottom:8px;" mode="aspectFit" />

    <text style="font-size:32px; font-weight:900; color:#1A1A1A; letter-spacing:-0.01em;">OneLiner</text>
    <text style="font-size:14px; color:rgba(26,26,26,0.35); margin-top:10px;">登录后开始种下你的认知花园</text>

    <button
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
      style="width:80px; height:80px; border-radius:50%; padding:0; margin:32px 0 0; overflow:hidden; background:rgba(26,26,26,0.04); border:2px dashed rgba(26,26,26,0.1); display:flex; align-items:center; justify-content:center;"
    >
      <image
        wx:if="{{avatarUrl}}"
        src="{{avatarUrl}}"
        style="width:80px; height:80px; border-radius:50%;"
      />
      <view wx:else style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:80px; height:80px;">
        <text style="font-size:24px;">👤</text>
        <text style="font-size:10px; color:rgba(26,26,26,0.25); margin-top:4px;">选头像</text>
      </view>
    </button>

    <view style="width:100%; margin-top:24px;">
      <input
        type="nickname"
        placeholder="你的名字"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
        style="width:100%; height:48px; border-radius:50px; padding:0 24px; font-size:15px; font-weight:500; color:#1A1A1A; background:#FAF7F2; border:none; text-align:center; box-shadow:0 1px 4px rgba(26,26,26,0.03);"
        placeholder-style="color:rgba(26,26,26,0.2);"
      />
    </view>

    <view
      style="width:100%; margin-top:24px; padding:15px 0; border-radius:50px; text-align:center; background:#1A1A1A; opacity:{{canSubmit ? 1 : 0.2}};"
      bindtap="onTapConfirm"
    >
      <text style="color:#F2EDE7; font-size:15px; font-weight:700;">开始探索</text>
    </view>

    <view style="margin-top:20px;" bindtap="onTapSkip">
      <text style="font-size:12px; color:rgba(26,26,26,0.2);">先逛逛再说</text>
    </view>
  </view>
</view>
