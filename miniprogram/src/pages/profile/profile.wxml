<view class="flex flex-col w-full relative" style="height:100vh; overflow:hidden; background:#F2EDE7;">

  <view style="padding:56px 20px 0; position:relative; z-index:10;">
    <view class="flex items-center" style="justify-content:center;">
      <text style="font-size:16px; font-weight:900; color:#1A1A1A;">我的</text>
    </view>
  </view>

  <view style="flex:1; display:flex; flex-direction:column; padding:0 20px;">

    <view wx:if="{{loggedIn}}" class="flex flex-col items-center" style="padding:40px 0 20px;">
      <image
        wx:if="{{avatarUrl}}"
        src="{{avatarUrl}}"
        style="width:72px; height:72px; border-radius:50%; margin-bottom:12px; background:rgba(26,26,26,0.04);"
        mode="aspectFill"
      />
      <view
        wx:else
        style="width:72px; height:72px; border-radius:50%; margin-bottom:12px; background:rgba(26,26,26,0.06); display:flex; align-items:center; justify-content:center;"
      >
        <text style="font-size:28px; color:rgba(26,26,26,0.15);">👤</text>
      </view>
      <text style="font-size:16px; font-weight:700; color:#1A1A1A;">{{nickname || '未设置昵称'}}</text>
    </view>

    <view wx:else class="flex flex-col items-center" style="padding:40px 0 20px;">
      <view
        style="width:72px; height:72px; border-radius:50%; margin-bottom:12px; background:rgba(26,26,26,0.06); display:flex; align-items:center; justify-content:center;"
      >
        <text style="font-size:28px; color:rgba(26,26,26,0.15);">👤</text>
      </view>
      <view
        style="padding:10px 28px; border-radius:50px; background:#1A1A1A; margin-top:8px;"
        bindtap="onTapLogin"
      >
        <text style="color:#F2EDE7; font-size:14px; font-weight:700;">点击登录</text>
      </view>
    </view>

    <view wx:if="{{loggedIn}}" style="margin-top:20px;">
      <view style="display:flex; align-items:center; gap:6px; margin-bottom:12px; padding:0 4px;">
        <view style="flex:1; height:1px; background:rgba(26,26,26,0.06);"></view>
        <text style="font-size:11px; font-weight:600; color:rgba(26,26,26,0.2); letter-spacing:0.08em;">账号</text>
        <view style="flex:1; height:1px; background:rgba(26,26,26,0.06);"></view>
      </view>
      <view
        style="padding:16px 18px; border-radius:16px; background:#FAF7F2; box-shadow:0 1px 3px rgba(26,26,26,0.03);"
        bindtap="onTapLogout"
      >
        <text style="font-size:14px; color:rgba(26,26,26,0.4); font-weight:500;">退出登录</text>
      </view>
    </view>

    <view style="flex:1;"></view>

    <view class="flex items-center justify-center" style="padding:20px 0;">
      <text style="font-size:11px; color:rgba(26,26,26,0.12); font-weight:500;">OneLiner {{version}}</text>
    </view>
  </view>

  <view style="display:flex; align-items:center; justify-content:center; gap:32px; padding:10px 0 28px; position:relative; z-index:20; border-top:1px solid rgba(26,26,26,0.06);">
    <view class="flex flex-col items-center" style="gap:2px;" bindtap="goToIndex">
      <text style="font-size:18px;">📖</text>
      <text style="font-size:10px; font-weight:600; color:rgba(26,26,26,0.25);">翻翻</text>
    </view>
    <view class="flex flex-col items-center" style="gap:2px;" bindtap="goToMine">
      <text style="font-size:18px;">🌱</text>
      <text style="font-size:10px; font-weight:600; color:rgba(26,26,26,0.25);">花园</text>
    </view>
    <view class="flex flex-col items-center" style="gap:2px;">
      <text style="font-size:18px;">👤</text>
      <text style="font-size:10px; font-weight:600; color:#1A1A1A;">我的</text>
    </view>
  </view>

</view>
