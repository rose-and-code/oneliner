<view class="flex items-center justify-around w-full bg-bg pt-2 pb-6"
  style="position:fixed; bottom:0; left:0; right:0; z-index:999; border-top: 1px solid rgba(52, 211, 153, 0.06);">
  <view
    wx:for="{{tabs}}"
    wx:key="pagePath"
    class="flex flex-col items-center justify-center flex-1 py-1"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="flex items-center justify-center w-6 h-6 mb-1">
      <block wx:if="{{item.icon === 'book'}}">
        <text wx:if="{{selected === index}}" class="text-base text-accent">📖</text>
        <text wx:else class="text-base text-text-dim">📖</text>
      </block>
      <block wx:if="{{item.icon === 'star'}}">
        <text wx:if="{{selected === index}}" class="text-base text-accent">⭐</text>
        <text wx:else class="text-base text-text-dim">⭐</text>
      </block>
    </view>
    <text wx:if="{{selected === index}}" class="text-xs tracking-wider text-accent font-medium">{{item.text}}</text>
    <text wx:else class="text-xs tracking-wider text-text-dim">{{item.text}}</text>
  </view>
</view>
